# Copy to .env (gitignored). Everything here is OPTIONAL.
#
# RPC precedence everywhere (make targets AND direct `forge test` — the fork fixture
# resolves the same chain): explicit ETH_RPC_URL > ALCHEMY_API_KEY > public fallback
# (https://ethereum-rpc.publicnode.com, rate-limited — expect slower fork suites and
# the occasional 403 on archive requests).

# Alchemy API key (key only, not the full URL) — composed into
# https://eth-mainnet.g.alchemy.com/v2/<key> when ETH_RPC_URL is unset.
ALCHEMY_API_KEY=

# Or pin a full RPC URL directly (wins over ALCHEMY_API_KEY).
#ETH_RPC_URL=
